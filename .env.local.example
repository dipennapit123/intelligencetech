# ── Intelligence Tech Web (public site + API) ─────────────────────────────
# Copy to .env.local and replace placeholders. Never commit .env.local.
#
# Supabase: Dashboard → Settings → API
# Admin login email must match INTELTECH_ADMIN_EMAILS (comma-separated).

# Site URL (canonical, used in metadata / absolute URLs when set)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — public (safe for browser; use the anon key)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# Supabase — server only (API routes use this; keep secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# Who may call /api/admin/* (must match Supabase Auth user email after login)
# Default dev account: admin@gmail.com — create with: npm run seed:admin
INTELTECH_ADMIN_EMAILS=admin@gmail.com

# ── Contact form (POST /api/contact) — Resend: https://resend.com
# After domain verification, set RESEND_FROM_EMAIL to e.g. "Intelligence Tech <hello@yourdomain.com>"
RESEND_API_KEY=re_xxxxxxxx
# Optional — defaults to first address in INTELTECH_ADMIN_EMAILS
# CONTACT_INBOX_EMAIL=you@yourdomain.com
# RESEND_FROM_EMAIL=Intelligence Tech <onboarding@resend.dev>
